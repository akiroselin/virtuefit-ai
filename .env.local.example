# AI Generation Service Configuration
# Options:
# - USE_TRIPO=true  : Tripo3D (3D model generation) - recommended
# - USE_COMFYUI=true: ComfyUI (image generation, local Windows)
# - Neither          : Mock generation (demo mode)

USE_TRIPO=false
USE_COMFYUI=false

# Tripo3D Configuration (3D Model Generation)
# Get API key from: https://dashboard.tripo3d.ai
# Fast generation with PBR textures
TRIPO_API_KEY=

# ComfyUI Configuration (Image Generation)
# Run locally on Windows, use ngrok for external access
COMFYUI_API_URL=
COMFYUI_API_KEY=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
