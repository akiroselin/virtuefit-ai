# AI Generation Service Configuration
# Options: mock (demo), meshy (3D models), comfyui (image generation)
# Set USE_MESHY=true to use Meshy.ai for 3D model generation
# Set USE_COMFYUI=true to use local ComfyUI

USE_MESHY=false
USE_COMFYUI=false

# Meshy.ai Configuration (3D Model Generation)
# Get API key from: https://dashboard.meshy.ai/api
# Free tier: 200 credits/month
MESHY_API_KEY=

# ComfyUI Configuration (Image Generation)
# Run locally on Windows, use ngrok for external access
COMFYUI_API_URL=
COMFYUI_API_KEY=

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
