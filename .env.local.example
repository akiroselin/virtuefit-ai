# AI Generation Service Configuration
# Set USE_ZMO=true to use ZMO.AI, false to use ComfyUI
USE_ZMO=true

# ZMO.AI API Configuration
# Get your API key from: https://dashboard.zmo.ai/api
ZMO_API_KEY=your_zmo_api_key_here

# ComfyUI Configuration (fallback)
COMFYUI_API_URL=https://your-comfyui-server.com
COMFYUI_API_KEY=your_comfyui_api_key_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
